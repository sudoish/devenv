[
  {
    "context": "Editor && (vim_mode == normal || vim_mode == visual) && !VimWaiting && !menu",
    "bindings": {
      // put key-bindings here if you want them to work in normal & visual mode
      // Toggle/untoggle file tree with leader + m
      // "space m": "project_panel::ToggleFocus"
    }
  },
  {
    "context": "Editor && vim_mode == normal && !VimWaiting && !menu",
    "bindings": {
      // put key-bindings here if you want them to work only in normal mode
      // "down": ["workspace::SendKeystrokes", "4 j"]
      // "up": ["workspace::SendKeystrokes", "4 k"]
      "space f s": "workspace::Save",
      "space s f": "file_finder::Toggle",
      "space s g": "pane::DeploySearch",
      "space ;": "terminal_panel::ToggleFocus",
      "t t": "editor::SpawnNearestTask",
      "t f": [
        "task::Spawn",
        {
          "task_name": "pytest: Run tests for current file"
        }
      ],
      "t n": "task::Spawn",
      "t s": [
        "task::Spawn",
        {
          "task_name": "start-services"
        }
      ],
      // Editor
      "space r": "editor::Rename",
      // Navigation
      "space tab": "tab_switcher::Toggle",
      "g h": "pane::GoBack",
      "g l": "pane::GoForward",
      "L": "pane::ActivateNextItem",
      "H": "pane::ActivatePreviousItem",
      // Project
      "z a": "editor::ToggleFold",
      // Diagnostics
      "[ d": "editor::GoToPreviousDiagnostic",
      "] d": "editor::GoToDiagnostic",
      "space q": "pane::CloseActiveItem",
      // Git commands
      "space f f": "file_finder::Toggle",
      // Project tree: `-` reveals the current file in the panel (opens + focuses
      // the left dock and jumps to the file). `_` opens the tree at the project
      // root — Zed has no single "open at root" action, so chain it: reveal (to
      // focus the panel) → collapse all → select first. The `z m` / `g g` legs
      // are bound in the ProjectPanel context below.
      "-": "pane::RevealInProjectPanel",
      "_": ["workspace::SendKeystrokes", "- z m g g"],
      // AI
      // Command K to open ai inline
      "cmd-k": "assistant::InlineAssist",
      "cmd-i": "agent::ToggleFocus",
      "space l g": [
        "task::Spawn",
        {
          "task_name": "lazygit"
        }
      ],
      "space g b": "git::Branch",
      "cmd-enter": "agent::KeepAll",
      // Worktree (D3): replaces nvim <leader>at task-workflow. Creates/switches a
      // git worktree; run the agent panel (cmd-i) inside it for AI-in-worktree.
      "space a t": "git::Worktree",
      "space o s": [
        "task::Spawn",
        {
          "task_name": "obsidian-search"
        }
      ],
      "space o n": [
        "task::Spawn",
        {
          "task_name": "obsidian-new"
        }
      ],
      "space o d": [
        "task::Spawn",
        {
          "task_name": "obsidian-daily"
        }
      ],
      "space e": "editor::ToggleTabBar",
      "ctrl-h": ["workspace::ActivatePaneInDirection", "Left"],
      "ctrl-j": ["workspace::ActivatePaneInDirection", "Down"],
      "ctrl-k": ["workspace::ActivatePaneInDirection", "Up"],
      "ctrl-l": ["workspace::ActivatePaneInDirection", "Right"],
      // tmux-prefix-style window-tab switch (shadows vim ctrl-a increment here)
      "ctrl-a h": "window::ShowPreviousWindowTab",
      "ctrl-a l": "window::ShowNextWindowTab"
    }
  },
  {
    "context": "Editor && vim_mode == visual && !VimWaiting && !menu",
    "bindings": {
      // visual, visual line & visual block modes
      "cmd-i": "assistant::QuoteSelection",
      "cmd-k": "assistant::InlineAssist"
    }
  },
  {
    "context": "Editor && vim_mode == insert && !menu",
    "bindings": {
      // nvim parity: `jk` escapes to normal mode (mappings.lua `map("i","jk","<ESC>")`)
      "j k": "vim::NormalBefore"
    }
  },
  {
    "context": "Terminal",
    "bindings": {
      // put key-bindings here if you want them to work in insert mode
      // e.g.
      // "j j": "vim::NormalBefore" // remap jj in insert mode to escape.
      "cmd-k": "assistant::InlineAssist",
      "cmd-i": "agent::Chat"
    }
  },
  {
    "context": "ProjectPanel && !editing",
    "bindings": {
      // put key-bindings here if you want them to work in file finder
      // e.g.
      // "j j": "vim::NormalBefore" // remap jj in insert mode to escape.
      "a": "project_panel::NewFile",
      "d": "project_panel::Delete",
      "r": "project_panel::Rename",
      "q": "workspace::ToggleLeftDock",
      "-": "workspace::ToggleLeftDock",
      // Root navigation: `g g` jumps to the top entry, `z m` collapses the whole
      // tree. The editor's `_` SendKeystrokes chain drives both; `_` here also
      // re-roots when focus is already in the panel.
      "g g": "menu::SelectFirst",
      "z m": "project_panel::CollapseAllEntries",
      "_": "project_panel::CollapseAllEntries",
      "cmd-w": "workspace::CloseAllDocks"
    }
  },
  {
    "context": "!Editor && !menu",
    "bindings": {
      // "space q": "workspace::CloseWindow",
      // "space f f": "file_finder::Toggle"
      // "space m": "workspace::ToggleLeftDock"
    }
  },
  {
    "context": "GitPanel && !CommitEditor",
    "bindings": {
      "s": "git::UnstageAll",
      "c": "git::Commit",
      "space q": "git_panel::Close",
      "escape": "git_panel::Close"
    }
  },
  {
    "context": "GitPanel && CommitEditor",
    "bindings": {
      "escape": "git_panel::Close"
    }
  },
  {
    "context": "AgentPanel && thread_list",
    "bindings": {}
  },
  {
    // Chat input (ACP agents + Zed-native): scroll the transcript WITHOUT leaving
    // the input. Zed keeps focus in the input box — the history isn't a vim-focus
    // target — so ctrl-k/ctrl-j scroll via actions instead of moving focus.
    "context": "(AcpThread > Editor) || (MessageEditor > Editor)",
    "bindings": {
      "ctrl-k": "agent::ScrollOutputLineUp",
      "ctrl-j": "agent::ScrollOutputLineDown"
    }
  },
  {
    // Chat transcript when focused directly (e.g. clicked in): bare vim j/k scroll.
    "context": "AgentPanel && !MessageEditor",
    "bindings": {
      "j": "agent::ScrollOutputLineDown",
      "k": "agent::ScrollOutputLineUp"
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-h": ["workspace::ActivatePaneInDirection", "Left"],
      "ctrl-j": ["workspace::ActivatePaneInDirection", "Down"],
      "ctrl-k": ["workspace::ActivatePaneInDirection", "Up"],
      "ctrl-l": ["workspace::ActivatePaneInDirection", "Right"],
      // tmux-prefix-style window-tab switch (left / right) across open projects
      "ctrl-a h": "window::ShowPreviousWindowTab",
      "ctrl-a l": "window::ShowNextWindowTab"
    }
  }
]
